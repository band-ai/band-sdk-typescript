# Thenvoi SDK local environment (copy to .env)
# Gitignored — do not commit secrets.

# OpenAI (ToolCalling / memory examples)
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Thenvoi platform
THENVOI_REST_URL=https://app.thenvoi.com
THENVOI_WS_URL=wss://app.thenvoi.com/api/v1/socket/websocket

# User API key — required for openai-memory-e2e trigger messages
THENVOI_API_KEY_USER=your_user_api_key_here

# Live E2E harness (set to 1 when running openai-memory-e2e.ts)
# RUN_OPENAI_MEMORY_E2E=1
E2E_TIMEOUT=30
