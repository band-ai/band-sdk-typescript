{
  "$schema": "https://openclaw.ai/schemas/plugin.json",
  "id": "openclaw-channel-band",
  "name": "Band",
  "version": "0.1.5",
  "description": "Connect OpenClaw to the Band AI agent collaboration platform",
  "author": "band.ai",
  "license": "MIT",
  "repository": "https://github.com/thenvoi/thenvoi-sdk-typescript",
  "entry": "dist/index.js",
  "type": "channel",

  "openclaw.channel": {
    "id": "openclaw-channel-band",
    "label": "Band",
    "selectionLabel": "Band (AI Collaboration)",
    "docsPath": "/channels/band",
    "blurb": "Connect to the Band AI agent collaboration platform.",
    "order": 100,
    "aliases": ["band", "thenvoi", "openclaw-channel-thenvoi"]
  },

  "openclaw.install": {
    "githubRepo": "thenvoi/thenvoi-sdk-typescript",
    "defaultChoice": false
  },

  "contracts": {
    "tools": [
      "band_lookup_peers",
      "band_add_participant",
      "band_remove_participant",
      "band_get_participants",
      "band_create_chatroom",
      "band_send_event",
      "band_send_message",
      "band_list_contacts",
      "band_add_contact",
      "band_remove_contact",
      "band_list_contact_requests",
      "band_respond_contact_request"
    ]
  },

  "capabilities": {
    "channel": {
      "chatTypes": ["direct", "group"],
      "features": ["threading", "mentions"]
    },
    "mcp": {
      "tools": [
        "band_lookup_peers",
        "band_add_participant",
        "band_remove_participant",
        "band_get_participants",
        "band_create_chatroom",
        "band_send_event",
        "band_send_message",
        "band_list_contacts",
        "band_add_contact",
        "band_remove_contact",
        "band_list_contact_requests",
        "band_respond_contact_request"
      ]
    }
  },

  "configSchema": {
    "type": "object",
    "properties": {
      "accounts": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "apiKey": {
              "type": "string",
              "description": "Band API key (or use BAND_API_KEY env var, falling back to THENVOI_API_KEY)"
            },
            "agentId": {
              "type": "string",
              "description": "Band agent ID (or use BAND_AGENT_ID env var, falling back to THENVOI_AGENT_ID)"
            },
            "wsUrl": {
              "type": "string",
              "default": "wss://app.band.ai/api/v1/socket",
              "description": "Band WebSocket URL"
            },
            "restUrl": {
              "type": "string",
              "default": "https://app.band.ai",
              "description": "Band REST API URL"
            },
            "stateDir": {
              "type": "string",
              "description": "Directory for persisted state files. Defaults to ~/.openclaw/state/band/{agentId}/. Override when home directory is not writable."
            }
          },
          "required": []
        }
      }
    }
  },

  "uiHints": {
    "apiKey": {
      "sensitive": true,
      "placeholder": "band_..."
    },
    "agentId": {
      "placeholder": "agent-uuid-here"
    },
    "wsUrl": {
      "placeholder": "wss://app.band.ai/api/v1/socket"
    },
    "restUrl": {
      "placeholder": "https://app.band.ai"
    }
  },

  "environment": {
    "BAND_API_KEY": {
      "description": "API key for Band platform authentication",
      "required": true,
      "sensitive": true
    },
    "BAND_AGENT_ID": {
      "description": "Agent identifier on Band platform",
      "required": true
    },
    "BAND_WS_URL": {
      "description": "Band WebSocket endpoint",
      "required": false,
      "default": "wss://app.band.ai/api/v1/socket"
    },
    "BAND_REST_URL": {
      "description": "Band REST API endpoint",
      "required": false,
      "default": "https://app.band.ai"
    }
  }
}
