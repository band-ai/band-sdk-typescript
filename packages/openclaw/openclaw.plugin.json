{
  "$schema": "https://openclaw.ai/schemas/plugin.json",
  "id": "openclaw-channel-band",
  "name": "Band",
  "version": "0.1.8",
  "description": "Connect OpenClaw to the Band AI agent collaboration platform",
  "author": "Band",
  "license": "MIT",
  "repository": "https://github.com/thenvoi/thenvoi-sdk-typescript",
  "kind": "channel",
  "entry": "dist/index.js",
  "setupEntry": "dist/setup-entry.js",
  "channels": [
    "openclaw-channel-band"
  ],
  "configSchema": {
    "type": "object",
    "properties": {
      "accounts": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "apiKey": {
              "type": "string",
              "description": "Band API key (or use BAND_API_KEY env var)"
            },
            "agentId": {
              "type": "string",
              "description": "Band agent ID (or use BAND_AGENT_ID env var)"
            },
            "wsUrl": {
              "type": "string",
              "default": "wss://app.thenvoi.com/api/v1/socket",
              "description": "Band WebSocket URL"
            },
            "restUrl": {
              "type": "string",
              "default": "https://app.thenvoi.com",
              "description": "Band REST API URL"
            },
            "stateDir": {
              "type": "string",
              "description": "Directory for persisted state files (e.g. the main-channel hub id)."
            }
          },
          "required": []
        }
      }
    }
  },
  "openclaw.channel": {
    "id": "openclaw-channel-band",
    "label": "Band",
    "selectionLabel": "Band (AI Collaboration)",
    "docsPath": "/channels/band",
    "blurb": "Connect to the Band AI agent collaboration platform.",
    "order": 100,
    "aliases": [
      "band"
    ]
  },
  "openclaw.install": {
    "githubRepo": "thenvoi/thenvoi-sdk-typescript",
    "defaultChoice": false
  },
  "contracts": {
    "tools": [
      "band_lookup_peers",
      "band_add_participant",
      "band_remove_participant",
      "band_get_participants",
      "band_create_chatroom",
      "band_send_event",
      "band_list_chats",
      "band_list_contacts",
      "band_add_contact",
      "band_remove_contact",
      "band_list_contact_requests",
      "band_respond_contact_request"
    ]
  },
  "capabilities": {
    "channel": {
      "chatTypes": [
        "direct",
        "group"
      ],
      "features": [
        "threading",
        "mentions"
      ]
    },
    "mcp": {
      "tools": [
        "band_lookup_peers",
        "band_add_participant",
        "band_remove_participant",
        "band_get_participants",
        "band_create_chatroom",
        "band_send_event",
        "band_list_chats",
        "band_list_contacts",
        "band_add_contact",
        "band_remove_contact",
        "band_list_contact_requests",
        "band_respond_contact_request"
      ]
    }
  },
  "channelConfigs": {
    "openclaw-channel-band": {
      "schema": {
        "type": "object",
        "properties": {
          "accounts": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true
                },
                "apiKey": {
                  "type": "string",
                  "description": "Band API key (or use BAND_API_KEY env var)"
                },
                "agentId": {
                  "type": "string",
                  "description": "Band agent ID (or use BAND_AGENT_ID env var)"
                },
                "wsUrl": {
                  "type": "string",
                  "default": "wss://app.thenvoi.com/api/v1/socket",
                  "description": "Band WebSocket URL"
                },
                "restUrl": {
                  "type": "string",
                  "default": "https://app.thenvoi.com",
                  "description": "Band REST API URL"
                },
                "stateDir": {
                  "type": "string",
                  "description": "Directory for persisted state files (e.g. the main-channel hub id)."
                }
              },
              "required": []
            }
          }
        }
      },
      "uiHints": {
        "apiKey": {
          "label": "API key",
          "sensitive": true,
          "placeholder": "tv_..."
        },
        "agentId": {
          "label": "Agent ID",
          "placeholder": "agent-uuid-here"
        },
        "wsUrl": {
          "label": "WebSocket URL",
          "placeholder": "wss://app.thenvoi.com/api/v1/socket"
        },
        "restUrl": {
          "label": "REST URL",
          "placeholder": "https://app.thenvoi.com"
        }
      }
    }
  },
  "environment": {
    "BAND_API_KEY": {
      "description": "API key for Band platform authentication",
      "required": true,
      "sensitive": true
    },
    "BAND_AGENT_ID": {
      "description": "Agent identifier on the Band platform",
      "required": true
    },
    "BAND_WS_URL": {
      "description": "Band WebSocket endpoint",
      "required": false,
      "default": "wss://app.thenvoi.com/api/v1/socket"
    },
    "BAND_REST_URL": {
      "description": "Band REST API endpoint",
      "required": false,
      "default": "https://app.thenvoi.com"
    }
  }
}
